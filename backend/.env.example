PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ebs_grades
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Cloudinary — https://cloudinary.com/console дээрээс авна
CLOUDINARY_CLOUD_NAME=your_cloud_name
